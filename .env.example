# Modo de base de datos (valores permitidos: sqlite, postgres)
DB_MODE=postgres

# Archivo origen de los datos
ARCHIVO_EXCEL=01312026BUMDH040226V2MC_SPSS.sav
#ARCHIVO_EXCEL=test.xlsx
NOMBRE_TABLA=py_vis

# --- Credenciales para PostgreSQL ---
# (Solo se usan si DB_MODE=postgres)
DB_USER=xxxx
DB_PASSWORD=xxxxx
DB_HOST=xxxx
DB_PORT=5432
DB_NAME=xxx

# --- Configuración para SQLite ---
# (Solo se usa si DB_MODE=sqlite)
SQLITE_PATH=pruebas.db
